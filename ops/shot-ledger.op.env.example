# Copy this file to ~/.config/shot-ledger/proof.env with mode 600.
# Replace each placeholder with a 1Password secret reference, not a value.

B2_KEY_ID=op://<vault>/<shot-ledger-b2-item>/keyID
B2_APP_KEY=op://<vault>/<shot-ledger-b2-item>/applicationKey
B2_BUCKET=naumio-shot-ledger-proof-2026
B2_REGION=us-east-005

OPENAI_API_KEY=op://<vault>/<openai-item>/credential
SHOT_LEDGER_PROVIDER=openai
SHOT_LEDGER_OPENAI_MODEL=gpt-image-2
