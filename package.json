{
  "name": "shot-ledger-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:public": ".venv/bin/python -m shot_ledger.export_worker_demo",
    "types": "wrangler types worker-configuration.d.ts --env production",
    "typecheck": "tsc --noEmit",
    "test:worker": "vitest run worker/test",
    "check:worker": "npm run build:public && npm run types && npm run typecheck && npm run test:worker && wrangler deploy --dry-run --env=\"\"",
    "deploy:preview": "npm run build:public && wrangler deploy --env=\"\"",
    "deploy:production": "npm run build:public && wrangler deploy --env production"
  },
  "dependencies": {
    "aws4fetch": "1.0.20"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
