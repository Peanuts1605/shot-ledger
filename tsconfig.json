{
  "compilerOptions": {
    "allowJs": false,
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["worker-configuration.d.ts", "worker/src/**/*.ts", "worker/test/**/*.ts"]
}
